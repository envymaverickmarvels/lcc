# Production Environment Variables
# Copy this file to .env and fill in the values

# Server
NODE_ENV=production
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/localmed

# Redis
REDIS_URL=redis://host:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://localmed.com,https://www.localmed.com

# API URLs
NEXT_PUBLIC_API_URL=https://api.localmed.com
NEXT_PUBLIC_WS_URL=wss://api.localmed.com

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# AWS S3 (for prescription images)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=localmed-prescriptions
AWS_REGION=ap-south-1

# Twilio (for OTP SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your-fcm-server-key

# Monitoring
SENTRY_DSN=your-sentry-dsn
