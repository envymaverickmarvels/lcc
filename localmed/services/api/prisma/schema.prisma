generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  email         String?   @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  avatarUrl     String?   @map("avatar_url")
  dateOfBirth   DateTime? @map("date_of_birth")
  gender        String?
  bloodType     String?   @map("blood_type")
  allergies     String[]
  chronicConditions String[] @map("chronic_conditions")
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  isPharmacyOwner Boolean @default(false) @map("is_pharmacy_owner")
  preferredLanguage String @default("en") @map("preferred_language")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  addresses     Address[]
  orders        Order[]
  prescriptions Prescription[]
  notifications Notification[]
  pharmacies    Pharmacy[]   @relation("PharmacyOwner")
  devices       UserDevice[]
  reviews       PharmacyReview[]

  @@map("users")
}

model Address {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String  @default("Home")
  fullName    String  @map("full_name")
  phone       String?
  addressLine1 String @map("address_line1")
  addressLine2 String? @map("address_line2")
  landmark    String?
  city        String
  state       String
  postalCode  String  @map("postal_code")
  country     String  @default("India")
  location    Unsupported("GEOGRAPHY(POINT, 4326)")?
  addressType String  @default("delivery") @map("address_type")
  isDefault   Boolean @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("addresses")
}

model UserDevice {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId         String   @map("device_id")
  deviceType       String   @map("device_type")
  deviceName       String?  @map("device_name")
  deviceModel      String?  @map("device_model")
  osVersion        String?  @map("os_version")
  pushEnabled      Boolean  @default(true) @map("push_enabled")
  notificationToken String? @map("notification_token")
  isActive         Boolean  @default(true) @map("is_active")
  lastActiveAt     DateTime? @map("last_active_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([userId, deviceId])
  @@map("user_devices")
}

model Pharmacy {
  id              String    @id @default(uuid())
  ownerId         String?   @map("owner_id")
  owner           User?     @relation("PharmacyOwner", fields: [ownerId], references: [id])
  name            String
  licenseNumber   String?   @map("license_number")
  address         String
  phone           String?
  email           String?
  location        Unsupported("GEOGRAPHY(POINT, 4326)")
  openingTime     String    @default("08:00") @map("opening_time")
  closingTime     String    @default("22:00") @map("closing_time")
  is24h           Boolean   @default(false) @map("is_24h")
  isDelivery      Boolean   @default(false) @map("is_delivery")
  deliveryRadiusKm Decimal? @map("delivery_radius_km")
  rating          Decimal   @default(0) @db.Decimal(2,1)
  totalReviews    Int       @default(0) @map("total_reviews")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  stock           PharmacyStock[]
  orders          Order[]
  operatingHours  PharmacyOperatingHour[]
  reviews         PharmacyReview[]
  photos          PharmacyPhoto[]

  @@index([ownerId])
  @@index([isActive])
  @@map("pharmacies")
}

model PharmacyOperatingHour {
  id          String @id @default(uuid())
  pharmacyId  String @map("pharmacy_id")
  pharmacy    Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  dayOfWeek   Int    @map("day_of_week")
  openingTime String @map("opening_time")
  closingTime String @map("closing_time")
  isClosed    Boolean @default(false) @map("is_closed")

  @@unique([pharmacyId, dayOfWeek])
  @@map("pharmacy_operating_hours")
}

model PharmacyReview {
  id          String   @id @default(uuid())
  pharmacyId  String   @map("pharmacy_id")
  pharmacy    Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating      Decimal  @db.Decimal(2,1)
  comment     String?
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([pharmacyId])
  @@map("pharmacy_reviews")
}

model PharmacyPhoto {
  id          String   @id @default(uuid())
  pharmacyId  String   @map("pharmacy_id")
  pharmacy    Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  url         String
  caption     String?
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([pharmacyId])
  @@map("pharmacy_photos")
}

model Medicine {
  id                String   @id @default(uuid())
  name              String
  genericName       String?  @map("generic_name")
  manufacturer      String?
  category          String?
  subcategory       String?  @map("subcategory")
  composition       String?
  dosageForm        String?  @map("dosage_form")
  strength          String?
  requiresPrescription Boolean @default(false) @map("requires_prescription")
  isEssential       Boolean  @default(false) @map("is_essential")
  imageUrl          String?  @map("image_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  stock             PharmacyStock[]
  orderItems        OrderItem[]
  alternatives      MedicineAlternative[] @relation("MedicineAlternative")
  alternativesOf    MedicineAlternative[] @relation("AlternativeOf")
  prescriptionMedicines PrescriptionMedicine[]

  @@index([name])
  @@index([category])
  @@map("medicines")
}

model MedicineAlternative {
  id            String   @id @default(uuid())
  medicineId     String   @map("medicine_id")
  medicine      Medicine @relation("MedicineAlternative", fields: [medicineId], references: [id])
  alternativeId String   @map("alternative_id")
  alternative   Medicine @relation("AlternativeOf", fields: [alternativeId], references: [id])

  @@unique([medicineId, alternativeId])
  @@map("medicine_alternatives")
}

model MedicineCategory {
  id        String   @id @default(uuid())
  name      String
  parentId  String?  @map("parent_id")
  parent    MedicineCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  MedicineCategory[] @relation("CategoryHierarchy")
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("medicine_categories")
}

model PharmacyStock {
  id              String    @id @default(uuid())
  pharmacyId      String    @map("pharmacy_id")
  pharmacy        Pharmacy  @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicineId      String    @map("medicine_id")
  medicine        Medicine  @relation(fields: [medicineId], references: [id])
  batchNumber     String?   @map("batch_number")
  expiryDate      DateTime? @map("expiry_date")
  mrp             Decimal?  @db.Decimal(10,2)
  sellingPrice    Decimal   @db.Decimal(10,2) @map("selling_price")
  costPrice       Decimal?  @db.Decimal(10,2) @map("cost_price")
  stockQuantity   Int       @default(0) @map("stock_quantity")
  reorderLevel    Int       @default(10) @map("reorder_level")
  isAvailable     Boolean   @default(true) @map("is_available")
  lastRestockedAt DateTime? @map("last_restocked_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  orderItems      OrderItem[]

  @@unique([pharmacyId, medicineId])
  @@index([pharmacyId])
  @@index([medicineId])
  @@map("pharmacy_stock")
}

model Order {
  id                  String    @id @default(uuid())
  orderNumber         String    @unique @map("order_number")
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id])
  pharmacyId          String    @map("pharmacy_id")
  pharmacy            Pharmacy  @relation(fields: [pharmacyId], references: [id])
  status              String    @default("pending")
  type                String    @default("pickup")
  deliveryAddress     Json?     @map("delivery_address")
  subtotal            Decimal   @default(0) @db.Decimal(10,2) @map("subtotal")
  deliveryFee         Decimal   @default(0) @db.Decimal(10,2) @map("delivery_fee")
  discount            Decimal   @default(0) @db.Decimal(10,2) @map("discount")
  totalAmount         Decimal   @default(0) @db.Decimal(10,2) @map("total_amount")
  prescriptionId      String?   @map("prescription_id")
  notes               String?
  estimatedPickupTime DateTime? @map("estimated_pickup_time")
  pickedUpAt          DateTime? @map("picked_up_at")
  cancelledAt         DateTime? @map("cancelled_at")
  cancellationReason  String?   @map("cancellation_reason")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  items               OrderItem[]

  @@index([userId])
  @@index([pharmacyId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicineId      String   @map("medicine_id")
  medicine        Medicine @relation(fields: [medicineId], references: [id])
  pharmacyStockId String?  @map("pharmacy_stock_id")
  pharmacyStock   PharmacyStock? @relation(fields: [pharmacyStockId], references: [id])
  medicineName    String?  @map("medicine_name")
  quantity        Int
  price           Decimal  @db.Decimal(10,2)
  total           Decimal  @db.Decimal(10,2)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([medicineId])
  @@map("order_items")
}

model Prescription {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  imageUrl        String   @map("image_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  extractedText   String?  @map("extracted_text")
  status          String   @default("pending")
  confidenceScore Decimal? @map("confidence_score") @db.Decimal(5,4)
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  medicines       PrescriptionMedicine[]

  @@index([userId])
  @@index([status])
  @@map("prescriptions")
}

model PrescriptionMedicine {
  id              String       @id @default(uuid())
  prescriptionId  String       @map("prescription_id")
  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId      String?      @map("medicine_id")
  medicine        Medicine?    @relation(fields: [medicineId], references: [id])
  name            String
  dosage          String?
  frequency       String?
  quantity        String?
  confidence      Decimal?    @db.Decimal(5,4)
  isVerified      Boolean      @default(false) @map("is_verified")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([prescriptionId])
  @@map("prescription_medicines")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  purpose   String   @default("login")
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@index([expiresAt])
  @@map("otps")
}
